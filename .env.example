# OpenAI — transcription (Whisper) + script generation (Chat Completions). Restart dev after changes.
OPENAI_API_KEY="sk-..."

# Optional (defaults: whisper-1, gpt-4o-mini)
# OPENAI_WHISPER_MODEL="whisper-1"
# OPENAI_CHAT_MODEL="gpt-4o-mini"

# UploadThing — only if you use image uploads in the app
UPLOADTHING_TOKEN="YOUR_UPLOADTHING_TOKEN"

# Supabase — Auth + Postgres (never commit real keys)
VITE_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"
