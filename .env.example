# OpenAI — script generation only (Chat Completions). Restart dev after changes.
OPENAI_API_KEY="sk-..."

# Google Gemini — video/audio transcription only (server /api/ai/transcribe)
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# Optional
# OPENAI_CHAT_MODEL="gpt-4o-mini"
# OPENAI_VEO_VISION_MODEL="gpt-4o"       # vision step (debut/fin stills) — default gpt-4o
# OPENAI_VEO_SCENE_MODEL="gpt-4o-mini"   # JSON package step only (/api/ai/veo-scene-package)
# GEMINI_TRANSCRIPTION_MODEL="gemini-2.5-flash"

# UploadThing — only if you use image uploads in the app
UPLOADTHING_TOKEN="YOUR_UPLOADTHING_TOKEN"

# Supabase — Auth + Postgres (never commit real keys)
VITE_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"
